---
import '../../sass/turtlenet.scss';
import TurtleNetSplash from './TurtleNetSplash.astro';
import TurtleNetFooter from './TurtleNetFooter.astro';
import {
  LATEST_VERSION,
  getPrimaryColor,
  type TurtleNetVersion,
} from '../../utils/turtlenet-versions';

interface PageInfo {
  order: number;
  title: string;
  slug: string;
}

interface Props {
  title: string;
  pages: PageInfo[];
  currentSlug: string;
  version: TurtleNetVersion;
  pagesByVersion: Record<TurtleNetVersion, PageInfo[]>;
  entry: {
    render: () => Promise<{ Content: any }>;
  };
}

const { title, pages, currentSlug, version, pagesByVersion, entry } = Astro.props;
const { Content } = await entry.render();

const isOldVersion = version !== LATEST_VERSION;
const bannerColor = getPrimaryColor(LATEST_VERSION);
const bodyClass = `tn-page${isOldVersion ? ` tn-page--${version}` : ''}`;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | TurtleNet | bencuan.me</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body class={bodyClass}>
    {isOldVersion && (
      <div class="tn-old-version-banner" style={`background-color: ${bannerColor};`}>
        You are currently viewing an old edition of TurtleNet! <a href="/turtlenet">click here</a> to view the new version.
      </div>
    )}
    <a href="https://bencuan.me" class="tn-go-home">
      <span class="tn-go-home__arrow">◀&#xFE0E;</span> go home
    </a>
    <TurtleNetSplash
      pages={pages}
      currentSlug={currentSlug}
      version={version}
      pagesByVersion={pagesByVersion}
    />

    <main class="tn-content">
      <div class="tn-content__inner">
        <h1 class="tn-content__title">{title}</h1>
        <div class="tn-content__body">
          <Content />
        </div>
      </div>
    </main>

    <TurtleNetFooter pages={pages} currentSlug={currentSlug} version={version} />
  </body>
</html>

