---
import { getCollection } from 'astro:content';

export const prerender = true;

const entries = await getCollection('turtlenet');
const sorted = entries.sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  sorted.map(async (entry) => {
    const { Content } = await entry.render();
    return { entry, Content };
  })
);
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1" />
    <title>TurtleNet — All Pages</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body>
    <!-- Go Home button -->
    <a class="go-home" href="/">← Go home</a>

    <!-- Splash banner -->
    <div class="splash">
      <img src="/img/turtlenet-2.png" alt="TurtleNet turtle" class="splash-img" />
      <h1 class="splash-title">TurtleNet</h1>
      <p class="splash-subtitle">The complete guide — all pages in one place</p>
    </div>

    <!-- All sections -->
    <main class="content">
      {rendered.map(({ entry, Content }, i) => (
        <section class="turtlenet-section">
          <h2 class="section-title">{entry.data.title}</h2>
          <div class="section-body">
            <Content />
          </div>
          {i < rendered.length - 1 && <hr class="section-divider" />}
        </section>
      ))}
    </main>

    <!-- Footer -->
    <footer class="turtlenet-footer">
      <img src="/img/friends/turtlenet.gif" alt="TurtleNet" class="footer-gif" />
    </footer>

    <style lang="scss">
      @use '../../sass/fonts';
      @use '../../sass/colors';
      @use '../../sass/mixins';

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background-color: colors.$background;
        overflow-x: hidden;
        line-height: 1.5;
      }

      .go-home {
        position: fixed;
        top: 1rem;
        left: 1rem;
        z-index: 100;
        background: rgba(255, 255, 255, 0.9);
        color: #203c7f;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        text-decoration: none;
        font-family: fonts.$frama;
        font-weight: 500;
        font-size: fonts.$s-1;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
        transition: background 0.2s;

        &:hover {
          background: #fff;
        }
      }

      .splash {
        background-color: #203c7f;
        color: white;
        text-align: center;
        padding: 4rem 2rem 3rem;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      .splash-img {
        width: 120px;
        height: auto;
        margin-bottom: 1rem;
      }

      .splash-title {
        font-family: fonts.$supply-sans;
        font-weight: 700;
        font-size: fonts.$s7;
        margin: 0;
      }

      .splash-subtitle {
        font-family: fonts.$atkinson;
        font-size: fonts.$s1;
        margin: 0.5rem 0 0;
        opacity: 0.85;
      }

      .content {
        width: min(80vw, 800px);
        margin: 2rem auto;
        padding: 0 2rem;

        @include mixins.screen('mobile') {
          width: min(95vw, 800px);
          padding: 0 1rem;
        }
      }

      .section-title {
        font-family: fonts.$supply-sans;
        font-weight: 700;
        font-size: fonts.$s5;
        color: #203c7f;
        margin: 3rem 0 1.5rem;
        padding-top: 1rem;
      }

      .section-body {
        font-family: fonts.$atkinson;
        font-size: fonts.$s0;
        color: colors.$text;

        :global(h1),
        :global(h2),
        :global(h3),
        :global(h4) {
          font-family: fonts.$supply-sans;
          font-weight: 500;
          color: colors.$text;
        }

        :global(h2) { font-size: fonts.$s4; }
        :global(h3) { font-size: fonts.$s3; }

        :global(p),
        :global(ul),
        :global(ol) {
          font-family: fonts.$atkinson;
          font-size: fonts.$s0;
          line-height: 1.7;
        }

        :global(img) {
          max-width: 100%;
          height: auto;
          border-radius: 4px;
          margin: 1rem 0;
        }

        :global(a) {
          color: #203c7f;
          text-decoration: underline;
          text-decoration-thickness: 1px;
          text-underline-offset: 2px;

          &:hover {
            color: colors.$dark-green;
          }
        }

        :global(code) {
          font-family: fonts.$code;
          font-size: 0.9em;
        }

        :global(.astro-code) {
          padding: 1rem;
          border-radius: 5px;
          box-shadow: 0px 4px 15px -6px rgba(0, 0, 0, 0.75);
          overflow-x: auto;
        }

        :global(blockquote) {
          position: relative;
          margin: 0 0 1.5rem 0;
          padding: 1rem;
          background-color: colors.$background-light;

          &::before {
            content: '';
            background-color: colors.$light-green;
            position: absolute;
            top: 0;
            left: 0;
            height: 100%;
            width: 3px;
          }

          :global(p) {
            margin: 0;
          }
        }

        :global(strong) {
          font-weight: 700;
          color: colors.$text;
        }

        :global(table) {
          border-collapse: collapse;
          width: 100%;
          margin: 1rem 0;

          :global(th),
          :global(td) {
            border: 1px solid colors.$extra-light-green;
            padding: 0.5rem 0.75rem;
            text-align: left;
            font-family: fonts.$atkinson;
            font-size: fonts.$s-1;
          }

          :global(th) {
            background-color: colors.$background-light;
            font-weight: 700;
          }
        }
      }

      .section-divider {
        border: none;
        border-top: 2px solid colors.$extra-light-green;
        margin: 3rem 0;
      }

      .turtlenet-footer {
        text-align: center;
        padding: 3rem 2rem 4rem;

        .footer-gif {
          width: 80px;
          height: auto;
        }
      }
    </style>
  </body>
</html>

