---
import Layout from '../components/layout.astro';
import BlogCardGrid from '../components/BlogCardGrid.tsx';
import '../sass/home.scss';
import '../sass/blog.scss';
import { getCollection } from 'astro:content';
import Button from '../components/button';
import { Newspaper, Rss } from '@phosphor-icons/react';

const collection = await getCollection('blog');
const allItems = collection.map(item => ({
  ...item.data,
  slug: '/blog/' + item.slug,
}));

// Categorize posts into Publications and Play based on frontmatter category
const publicationItems = allItems.filter(item => item.category === 'publications');
const playItems = allItems.filter(item => item.category === 'play');

// Add special "research syllabus" entry to Publications section (from root collection)
const researchEntry = {
  title: "Ben's Research Syllabus",
  date: new Date('2026-01-27'),
  slug: '/research',
  description: 'notes on wandering',
  tags: 'foundations',
  image: 'research/og-image.png',
};
const publicationItemsWithResearch = [...publicationItems, researchEntry];

// Add special "colors" entry to Play section
const colorsEntry = {
  title: "ben's colors",
  date: new Date('2025-12-30'),
  slug: '/colors/about',
  description: 'interactive color exploration app',
  tags: 'play',
  image: 'opengraph/colors.png',
};
const playItemsWithColors = [...playItems, colorsEntry];
---

<Layout title="bencuan's blog" description="long-form writing projects" currPage="blog" bodyClass="blog-page-container">
  <h1 class="blog-title">blog</h1>
  <div class="blog-buttons">
    <Button href="/rss.xml"><Rss /> rss</Button>
    <Button href="https://bencuan.substack.com"><Newspaper /> newsletter</Button>
  </div>

  <h2 class="blog-section-title">publications</h2>
  <BlogCardGrid items={publicationItemsWithResearch} client:load />

  <h2 class="blog-section-title">play</h2>
  <BlogCardGrid items={playItemsWithColors} showBadges={false} client:load />
</Layout>
